# ------------------------------------------------------------
# Exploratory nonlinear threshold module
# ------------------------------------------------------------
install.packages("drc")
library(drc)

dose_dat <- panel %>%
  dplyr::select(country, watch_pct, ast_pct) %>%
  dplyr::filter(!is.na(watch_pct), !is.na(ast_pct)) %>%
  dplyr::arrange(watch_pct)

m_ll4 <- drc::drm(ast_pct ~ watch_pct, data = dose_dat, fct = drc::LL.4())
m_weibull <- drc::drm(ast_pct ~ watch_pct, data = dose_dat, fct = drc::W1.4())
m_ln <- drc::drm(ast_pct ~ watch_pct, data = dose_dat, fct = drc::LN.4())
AIC(m_ll4, m_weibull, m_ln)

newdat <- data.frame(
  watch_pct = seq(min(dose_dat$watch_pct), max(dose_dat$watch_pct), length.out = 200)
)

pred <- cbind(
  newdat,
  fitted = predict(m_ll4, newdata = newdat))

p_drc <- ggplot(dose_dat, aes(watch_pct, ast_pct)) +
  geom_point() +
  geom_line(data = pred, aes(watch_pct, fitted), linewidth = 1) +
  labs(
    title = "Nonlinear association between Watch share and AST coverage",
    x = "Watch share (%)",
    y = "AST coverage (%)")

ggsave(file.path(output_dir, "drc_watch_ast_curve.png"), p_drc, width = 8, height = 5, dpi = 300)

